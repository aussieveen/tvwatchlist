<?xml version="1.0" encoding="UTF-8"?>

<ruleset name="PHP_CodeSniffer">
    <!-- Config -->
    <arg name="basepath" value="."/>
    <arg name="cache" value=".phpcs-cache"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>

    <!-- Directories to scan -->
    <file>bin/</file>
    <file>config/</file>
    <file>public/</file>
    <file>src/</file>
    <file>tests/</file>

    <!-- Ignore generated/reference files -->
    <exclude-pattern>config/bootstrap.php</exclude-pattern>
    <exclude-pattern>config/reference.php</exclude-pattern>

    <!-- Ignore the migrations files, they are auto-generated -->
    <exclude-pattern>src/Migrations/*</exclude-pattern>

    <!-- PSR-12 Extended Coding Style -->
    <rule ref="PSR12" />

    <!-- Treat long lines as errors, not warnings -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="120"/>
        </properties>
    </rule>
</ruleset>
